---
interface Props {
  pathname?: string;
}
const { pathname = '/' } = Astro.props;
const isHome = pathname === '/';
const navItems = [
  { href: '/mission',  label: 'MISSION'  },
  { href: '/service',  label: 'PRODUCTS' },
  { href: '/message',  label: 'MESSAGE'  },
  { href: '/company',  label: 'COMPANY'  },
];
const mobileNavItems = [
  { href: '/',         label: 'TOP'      },
  { href: '/mission',  label: 'MISSION'  },
  { href: '/solution', label: 'SOLUTION' },
  { href: '/service',  label: 'SERVICE'  },
  { href: '/company',  label: 'COMPANY'  },
];
---

<header
  id="site-header"
  class:list={[
    'z-[1000]',
    isHome
      ? 'absolute left-0 right-0 top-[8px] md:top-[50px]'
      : 'relative bg-white shadow-[0_2px_20px_rgba(0,0,0,0.08)]',
  ]}
>

  <!-- Desktop header: Figma positions — logo top:73px, nav/contact top:88–93px -->
  <div
    id="header-desktop"
    class="hidden md:flex items-end justify-between"
  >
    <!-- Logo — navy blue, positioned in the white concave notch -->
    <a href="/" class="shrink-0" aria-label="WAKU BUILD トップへ">
      <img
        id="header-logo"
        src="/logo.svg"
        alt="WAKU BUILD"
        class="h-[64px] w-auto"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Desktop nav + CONTACT — right-aligned group -->
    <div class="flex items-center gap-[clamp(16px,3.27vw,50px)]">
      <nav class="flex items-center gap-[clamp(16px,3.27vw,50px)]" aria-label="メインナビゲーション">
        {navItems.map((item) => {
          const active = pathname === item.href || pathname.startsWith(item.href + '/');
          return (
            <a
              href={item.href}
              class={`font-['Gill_Sans',sans-serif] font-semibold text-base tracking-wide transition-colors duration-200 ${isHome ? 'text-white' : 'text-primary'}${active ? '' : ' opacity-90 hover:opacity-100'}`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <!-- Desktop CONTACT pill -->
      <a
        href="/contact"
        id="header-contact-btn"
        class={`shrink-0 flex items-center justify-center rounded-full font-['Gill_Sans',sans-serif] font-semibold text-base tracking-wide transition-all duration-200 w-[clamp(120px,13.56vw,208px)] h-[clamp(36px,3.26vw,50px)] ${isHome ? 'bg-white text-primary hover:bg-accent' : 'bg-primary text-white hover:bg-primary-dark'}`}
      >
        CONTACT
      </a>
    </div>
  </div>

  <!-- Mobile header bar -->
  <div class="md:hidden flex items-center justify-between pl-[26px] pr-8 h-[80px]">
    <a href="/" class="flex items-center shrink-0" aria-label="WAKU BUILD トップへ">
      <img
        id="header-logo-mobile"
        src="/logo.svg"
        alt="WAKU BUILD"
        class="h-10 w-auto transition-[filter] duration-300"
        loading="eager"
        decoding="async"
      />
    </a>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-toggle"
      type="button"
      aria-controls="mobile-menu"
      aria-expanded="false"
      class="flex flex-col justify-center items-end w-10 h-10 gap-2 rounded-lg focus:outline-none"
      aria-label="メニューを開く"
    >
      <span class={`block h-0.5 w-[25px] transition-all duration-200 ${isHome ? 'bg-white' : 'bg-primary'}`}></span>
      <span class={`block h-0.5 w-[16px] transition-all duration-200 ${isHome ? 'bg-white' : 'bg-primary'}`}></span>
      <span class={`block h-0.5 w-[25px] transition-all duration-200 ${isHome ? 'bg-white' : 'bg-primary'}`}></span>
    </button>
  </div>

</header>

<!-- Mobile full-screen overlay (outside <header> to cover everything) -->
<div
  id="mobile-menu"
  class="md:hidden hidden fixed inset-0 z-[998] bg-primary"
  aria-label="モバイルナビゲーション"
  role="dialog"
  aria-modal="true"
>

  <!-- Logo — centered, top:133px (Figma: left:152px w:76px on 375px canvas → centered) -->
  <div class="absolute top-[133px] left-1/2 -translate-x-1/2">
    <img
      src="/logo.svg"
      alt="WAKU BUILD"
      class="w-[76px] h-auto brightness-0 invert"
      loading="eager"
      decoding="async"
    />
  </div>

  <!-- Nav items — top:222px, each 43px apart (line-height:40px + 3px gap) -->
  <nav
    class="absolute top-[222px] left-1/2 -translate-x-1/2 flex flex-col items-center gap-[3px]"
    aria-label="モバイルメニュー"
  >
    {mobileNavItems.map((item) => {
      const active = pathname === item.href || (item.href !== '/' && pathname.startsWith(item.href + '/'));
      return (
        <a
          href={item.href}
          class:list={[
            "mobile-nav-link font-['Gill_Sans',sans-serif] font-semibold text-center text-white whitespace-nowrap transition-opacity duration-200 hover:opacity-70 text-base leading-10",
            { 'opacity-70': active },
          ]}
        >
          {item.label}
        </a>
      );
    })}
  </nav>

  <!-- CONTACT button — top:458px, 218×47px, centered (Figma: left:81px on 375px canvas) -->
  <a
    href="/contact"
    id="mobile-contact-btn"
    class="absolute top-[458px] left-1/2 -translate-x-1/2 flex items-center justify-center rounded-full bg-white text-primary font-['Gill_Sans',sans-serif] font-semibold tracking-wide hover:bg-accent transition-colors duration-200 w-[218px] h-[47px] text-base"
  >
    CONTACT
  </a>

</div>

<style>
  /* Figma: logo left 5.93%, nav right 9.19% of viewport width */
  #header-desktop {
    padding-left: 5.93%;
    padding-right: 9.19%;
    padding-top: 18px;
    padding-bottom: 14px;
  }

  /* Hamburger → X animation */
  #mobile-menu-toggle span {
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }
  /* bar 1: translate down + rotate 45° */
  #mobile-menu-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(10px) rotate(45deg);
  }
  /* bar 2: fade out */
  #mobile-menu-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  /* bar 3: translate up + rotate -45° */
  #mobile-menu-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-10px) rotate(-45deg);
  }
</style>

<script>
  // ── Mobile menu ──────────────────────────────────────────────
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu   = document.getElementById('mobile-menu');

  function openMenu() {
    if (!menu || !toggle) return;
    menu.classList.remove('hidden');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    if (!menu || !toggle) return;
    menu.classList.add('hidden');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  function toggleMenu() {
    if (toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    } else {
      openMenu();
    }
  }

  toggle?.addEventListener('click', toggleMenu);

  // Close when a nav link inside the overlay is clicked
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      closeMenu();
    }
  });
</script>
