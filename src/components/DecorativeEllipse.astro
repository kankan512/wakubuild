---
// Decorative filled ellipse — 192×152px, rotated -30°
// Usage: <DecorativeEllipse color="#ffe34a" class="absolute top-[-10px] right-[80px] z-10" />
// The parent is responsible for positioning via the `class` prop.

interface Props {
  color?: string;
  class?: string;
}

const {
  color = '#ffe34a',
  class: className = '',
} = Astro.props;
---

<div
  class:list={['pointer-events-none select-none w-[192px] h-[152px] rounded-full -rotate-[30deg]', className]}
  aria-hidden="true"
  style={`background:${color};`}
></div>
