---
// SERVICE section — Figma: "SERVICE" 66px heading, 27px 2-column bullet list
// Left col: DX伴走支援/社外CTO + AIリスキリング研修
// Right col: システム/アプリ開発
---

<section class="bg-white pt-20 pb-20 md:py-28">
  <div class="section-container">

    <!-- Heading row: "SERVICE" + "サービス" side by side -->
    <div class="flex flex-col md:flex-row md:flex-wrap md:items-baseline md:gap-4 gap-y-1 mb-10 md:mb-[78px]">
      <h2 class="font-display font-semibold text-primary leading-none text-[clamp(40px,4.3vw,66px)]">
        SERVICE
      </h2>
      <p class="font-sans font-bold text-primary text-[12px] md:text-[20px]">
        サービス
      </p>
    </div>

    <!-- 2-column bullet list (Figma: 27px text with divider lines below each item) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mx-auto max-w-[900px]">

      <!-- Left column -->
      <div>
        <div class="w-full max-w-[400px] border-b border-[#464646] py-5">
          <ul class="list-disc pl-5">
            <li
              class="font-sans font-bold text-[#464646] text-[clamp(16px,1.76vw,27px)] tracking-[0.05em]"
            >DX伴走支援/社外CTO</li>
          </ul>
        </div>
        <div class="w-full max-w-[400px] border-b border-[#464646] py-5">
          <ul class="list-disc pl-5">
            <li
              class="font-sans font-bold text-[#464646] text-[clamp(16px,1.76vw,27px)] tracking-[0.05em]"
            >AIリスキリング研修</li>
          </ul>
        </div>
      </div>

      <!-- Right column -->
      <div>
        <div class="w-full max-w-[400px] border-b border-[#464646] py-5">
          <ul class="list-disc pl-5">
            <li
              class="font-sans font-bold text-[#464646] text-[clamp(16px,1.76vw,27px)] tracking-[0.05em]"
            >システム/アプリ開発</li>
          </ul>
        </div>
      </div>

    </div><!-- end grid -->


</div>
</section>
