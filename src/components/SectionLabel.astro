---
interface Props {
  label: string;
  heading: string;
  description?: string;
  align?: 'left' | 'center';
  headingSize?: 'lg' | 'xl' | '2xl';
  labelClass?: string;
  headingClass?: string;
}

const {
  label,
  heading,
  description,
  align = 'left',
  headingSize = 'xl',
  labelClass = '',
  headingClass = '',
} = Astro.props;

const alignClass = align === 'center' ? 'text-center items-center' : 'text-left items-start';

const headingSizeMap: Record<string, string> = {
  lg:  'text-2xl md:text-3xl',
  xl:  'text-3xl md:text-4xl lg:text-5xl',
  '2xl': 'text-4xl md:text-5xl lg:text-6xl',
};
const headingClasses = headingSizeMap[headingSize] ?? headingSizeMap.xl;
---

<div class:list={['section-label-block flex flex-col gap-2', alignClass]}>
  <p class:list={['section-label', labelClass]}>{label}</p>
  <h2 class:list={[headingClasses, 'font-sans font-bold text-[#464646] leading-tight', headingClass]}>
    {heading}
  </h2>
  {description && (
    <p class:list={['mt-2 text-base text-slate-600 max-w-2xl', align === 'center' ? 'mx-auto' : '']}>
      {description}
    </p>
  )}
</div>
