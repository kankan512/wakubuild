---
const products = [
  {
    title: '議事録革命',
    description: 'AIが会議の音声を自動で文字起こし・要約。議事録作成の時間を大幅に削減します。',
    image: '/top/service-1.jpg',
    imageAlt: '議事録革命のサービスイメージ',
    imageClass: '',
  },
  {
    title: 'しあわせ日報',
    description: '従業員の日々の報告をAIが分析。マネジメントの質を向上させる日報ツールです。',
    image: '/top/service-2.jpg',
    imageAlt: 'しあわせ日報のサービスイメージ',
    imageClass: '',
  },
];
---

<section class="relative bg-white pt-20 md:pt-[clamp(110px,16vw,130px)]">
  <div
    class="pointer-events-none absolute right-[-96px] top-0 hidden aspect-square w-[clamp(220px,27vw,392px)] md:block"
    aria-hidden="true"
  >
    <img
      src="/top/mission-2.png"
      alt=""
      class="h-full w-full"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- SP: pink ellipse top-right (Figma node 1:382, overflows right edge) -->
  <img src="/shape/shape_pink.svg" class="pointer-events-none select-none absolute -top-20 right-[-100px] z-0 md:hidden w-[192px] h-[152px]" aria-hidden="true" />
  <!-- Desktop: pink ellipse bottom-left -->
  <img src="/shape/shape_pink.svg" class="pointer-events-none select-none absolute -bottom-6 left-[-28px] hidden md:block z-10 w-[192px] h-[152px]" aria-hidden="true" />

  <div class="relative">
    <div
      class="absolute inset-y-0 left-0 right-6 rounded-r-[20px] bg-accent md:left-[-12.1vw] md:right-[7.6vw] md:rounded-[50px] 2xl:left-[-185px] 2xl:right-[117px]"
      aria-hidden="true"
    ></div>

    <div class="section-container relative z-10 py-12 md:py-24">
      <div class="flex flex-col md:flex-row md:flex-wrap md:items-baseline md:gap-4 gap-y-1">
        <h2
          class="font-display font-semibold text-primary leading-none"
          style="font-size:clamp(40px,calc(27px + 3.4vw),66px);"
        >
          PRODUCTS
        </h2>
        <p class="font-sans font-bold text-primary text-[12px] md:text-[20px]">
          製品情報
        </p>
      </div>

      <!-- SP: small pink ellipse bottom-left (Figma node 1:638) — overflows left edge -->
      <img src="/shape/shape_pink.svg" class="pointer-events-none select-none absolute -bottom-4 -left-8 z-0 md:hidden w-[119px] h-[95px]" aria-hidden="true" />

      <div class="mt-12 grid gap-y-12 md:mt-16 md:grid-cols-2 md:gap-x-[4.25rem] md:gap-y-0">
        {products.map((product) => (
          <article class="mx-auto w-full max-w-[270px] md:max-w-[450px]">
            <div class="relative flex aspect-[45/31] items-center justify-center bg-white">
              <span
                class="absolute left-0 top-0 flex h-[24px] w-[60px] md:h-[41px] md:w-[101px] items-center justify-center bg-primary pt-0.5 font-futura text-[15px] md:text-[26px] leading-none text-white"
              >
                <span class="relative -top-[2px]">saas</span>
              </span>

              <img
                src={product.image}
                alt={product.imageAlt}
                class:list={[
                  'h-auto max-h-[80%] object-contain',
                  product.imageClass,
                ]}
                loading="lazy"
                decoding="async"
              />
            </div>

            <h3
              class="mt-5 text-center font-sans text-[18px] md:text-[clamp(26px,2.1vw,28px)] leading-tight font-extrabold tracking-[0.05em] text-[#464646]"
              style="font-variation-settings:'CTGR' 100,'wdth' 100;"
            >
              {product.title}
            </h3>
            <p
              class="mx-auto mt-3 max-w-[30rem] text-center text-[12px] md:text-[16px] leading-[1.8] text-[#464646] md:max-w-[20rem]"
            >
              {product.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
