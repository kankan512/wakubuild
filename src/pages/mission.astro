---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const values = ['自分が楽しむ', '相手を楽しませる', 'みんなで成長する'];
---

<Layout
  title="MISSION | WAKU BUILD"
  description="WAKU BUILD（ワクビル）のミッション・ビジョン・バリュー。わくわくを創るをミッションに掲げ、人とAIの協働でDXを推進します。"
  pathname="/mission"
>
  <PageHero title="MISSION" subtitle="わくわくを創る" />

  <!-- MISSION -->
  <section class="py-16 md:py-24 bg-white">
    <div class="section-container">
      <div class="max-w-2xl">
        <p class="section-label mb-4">MISSION</p>
        <h2 class="font-sans font-bold text-[#464646] text-4xl md:text-5xl leading-tight mb-6">
          わくわくを創る
        </h2>
        <p class="font-sans text-[#464646] text-base md:text-lg leading-relaxed">
          人とAIが協力し、毎日をより豊かに楽しくすること。それが私たちWAKU BUILDのミッションです。
          難しい技術を身近にし、現場に寄り添う伴走型の支援を通じて、すべての働く人にわくわくを届けます。
        </p>
      </div>
    </div>
  </section>

  <!-- VALUE -->
  <section class="py-16 md:py-24 bg-[#f7f7f5]">
    <div class="section-container">
      <p class="section-label mb-4">VALUE</p>
      <div class="mt-2 flex flex-col gap-6 max-w-xl">
        {values.map((v) => (
          <div class="border-b border-[#464646] pb-6">
            <p class="font-sans font-bold text-[#464646] text-2xl md:text-3xl">{v}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white mt-8 py-16 md:py-24">
    <div class="section-container">
      <div class="bg-accent rounded-3xl py-16 md:py-20 px-8 text-center max-w-4xl mx-auto">
        <p class="section-label mb-4">CONTACT</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-[#464646] mb-8">お問い合わせはこちら</h2>
        <a href="/contact" class="btn-primary">CONTACTへ</a>
      </div>
    </div>
  </section>
</Layout>
