---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';

const overviewItems = [
  { label: '社名',     value: 'WAKU BUILD（ワクビル）株式会社' },
  { label: '代表取締役', value: '田中 和志' },
  { label: '設立',     value: '2025年6月' },
  { label: '所在地',   value: '〒530-0001 大阪府大阪市北区梅田1丁目2番2号 大阪駅前第2ビル12-12' },
  { label: '事業内容', value: 'DX伴走支援 / AIリスキリング研修 / システム・アプリ開発' },
];

const timeline = [
  { year: '2025.06', text: 'WAKU BUILD（ワクビル）株式会社を設立。' },
  { year: '2025.09', text: 'DX伴走支援の提供を開始。' },
];
---

<Layout
  title="COMPANY | WAKU BUILD"
  description="WAKU BUILD（ワクビル）株式会社の会社概要・沿革をご紹介します。"
  pathname="/company"
>
  <PageHero title="COMPANY" subtitle="会社情報" />

  <!-- 会社概要 -->
  <section class="py-16 md:py-24 bg-white">
    <div class="section-container">
      <p class="section-label mb-1">OVERVIEW</p>
      <p class="font-sans font-bold text-[#464646] text-2xl md:text-3xl mb-8">会社概要</p>
      <dl class="max-w-2xl">
        {overviewItems.map((item) => (
          <div class="flex flex-col sm:flex-row sm:items-start gap-2 sm:gap-8 py-5 border-b border-[#464646]">
            <dt class="font-sans font-bold text-sm text-primary sm:w-28 shrink-0 pt-0.5">{item.label}</dt>
            <dd class="font-sans text-[#464646] text-base">{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- 沿革 -->
  <section class="py-16 md:py-24 bg-[#f7f7f5]">
    <div class="section-container">
      <p class="section-label mb-1">HISTORY</p>
      <p class="font-sans font-bold text-[#464646] text-2xl md:text-3xl mb-8">沿革</p>
      <ol class="max-w-xl">
        {timeline.map((item, i) => (
          <li class="relative flex gap-8 pb-8">
            <div class="shrink-0 flex flex-col items-center w-4">
              <div class="w-4 h-4 rounded-full bg-accent mt-1.5 shrink-0"></div>
              {i < timeline.length - 1 && (
                <div class="flex-1 w-0.5 bg-slate-200 mt-2"></div>
              )}
            </div>
            <div>
              <span class="font-display font-bold text-sm text-primary tracking-wider">{item.year}</span>
              <p class="mt-1 font-sans text-[#464646] text-base">{item.text}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-white mt-8 py-16 md:py-24">
    <div class="section-container">
      <div class="bg-accent rounded-3xl py-16 md:py-20 px-8 text-center max-w-4xl mx-auto">
        <p class="section-label mb-4">CONTACT</p>
        <h2 class="font-display font-bold text-3xl md:text-4xl text-[#464646] mb-8">お問い合わせはこちら</h2>
        <a href="/contact" class="btn-primary">CONTACTへ</a>
      </div>
    </div>
  </section>
</Layout>
