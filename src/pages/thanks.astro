---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
---
<Layout title="送信完了 | WAKU BUILD" description="" pathname="/thanks">
  <PageHero title="THANK YOU" subtitle="お問い合わせを受け付けました" />
  <section class="section-container py-16 md:py-24 text-center max-w-2xl mx-auto">
    <p class="text-[#464646] text-lg">お問い合わせありがとうございます。<br>内容を確認の上、担当者よりご連絡いたします。</p>
    <div class="mt-8 flex flex-wrap gap-4 justify-center">
      <a href="/" class="btn-primary">トップページへ</a>
      <a href="/service" class="btn-outline">サービスを見る</a>
    </div>
  </section>
</Layout>
